# Testnet OpenAPI — 复制为 env/.env.testnet 并填入密钥（本地）；CI 用 secrets + workflow env 默认值
# GitHub Actions: ZOOMEX_TESTNET_API_KEY / ZOOMEX_TESTNET_API_SECRET

QA_BASE_URL=https://testnet.zoomex.com
QA_API_BASE_URL=https://openapi-testnet.zoomex.com

QA_API_KEY=
QA_API_SECRET=
QA_API_RECV_WINDOW=1000

QA_API_POSITION_MODE=hedge
QA_API_INVERSE_POSITION_MODE=oneway

# linear / spot 默认币对 ETHUSDT
QA_API_ORDER_SYMBOL=ETHUSDT
QA_API_ORDER_QTY=0.01
QA_API_MARKET_ORDER_QTY=0.01
QA_API_ORDER_PRICE=5000
QA_API_ORDER_AMEND_PRICE=4999
QA_API_SPOT_LIMIT_PRICE=100
QA_API_SPOT_LIMIT_AMEND_PRICE=101

# inverse（若启用 inverse spec）
QA_API_INVERSE_LIMIT_SIDE=Buy
QA_API_INVERSE_LIMIT_PRICE=100
QA_API_INVERSE_LIMIT_AMEND_PRICE=101
QA_API_INVERSE_MARKET_OPEN_SIDE=Buy
QA_API_INVERSE_MARKET_CLOSE_SIDE=Sell
