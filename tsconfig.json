{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@qa-e2e/api": ["qa-e2e/lib/api/index.ts"],
      "@qa-e2e/api/signed-request": ["qa-e2e/lib/api/signed-request.ts"],
      "@qa-e2e/api/*": ["qa-e2e/lib/api/*"],
      "@qa-e2e/*": ["qa-e2e/lib/*"],
      "@qa-perf/*": ["qa-perf/lib/*"]
    },
    "types": ["node", "@playwright/test"]
  },
  "include": ["qa-e2e/tests/**/*.ts", "qa-e2e/lib/**/*.ts"],
  "exclude": ["node_modules", "qa-results", "dist"]
}
